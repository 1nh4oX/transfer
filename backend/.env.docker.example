# Public base URL used in generated share links
BASE_URL=https://your-domain.com

# API exposed port on host
API_PORT=8080

# Postgres host exposed port (optional for local debugging)
POSTGRES_PORT=15432
POSTGRES_DB=transfer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

# App auth settings
JWT_SECRET=change-this-jwt-secret
DEMO_USERNAME=admin
DEMO_PASSWORD=change-this-demo-password
